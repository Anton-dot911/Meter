{
  "name": "meter-ts",
  "version": "0.0.0",
  "description": "Meter — fire-and-forget cost/latency tracking wrapper around the Anthropic SDK (TypeScript). Installed as a git dependency.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-prices.mjs",
    "prepare": "tsc -p tsconfig.json && node scripts/copy-prices.mjs",
    "test": "vitest run",
    "test:llm": "vitest run test/smoke.llm.test.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@types/node": "^26.1.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  }
}
